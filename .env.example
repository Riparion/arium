# arium — example environment file.
#
# Copy to `.env` and fill in real values. Everything here is optional with
# sane localhost defaults, EXCEPT the client id/secret pair for any OAuth
# provider you want to enable. A provider stays disabled until both its
# CLIENT_ID and CLIENT_SECRET are set and non-empty.
#
# `.env` is gitignored; this template (placeholders only, no secrets) is not.

# ── Public site ──────────────────────────────────────────────────────────────
# Base URL used to build links in outgoing email (verification, reset, etc.).
PUBLIC_BASE_URL=http://localhost:8080

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Sender address on outgoing mail. Default: noreply@localhost
FROM_EMAIL=noreply@localhost
# Leave SMTP_HOST unset/empty to use the dev file backend: emails are written
# as .eml files under ./emails/ instead of being sent. Set it to enable real
# SMTP delivery.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=apikey
#SMTP_PASSWORD=your-smtp-password

# ── Bootstrap admin ──────────────────────────────────────────────────────────
# On startup, the user with this email is promoted to admin (if present).
# DX_AUTH_BOOTSTRAP_ADMIN_EMAIL takes precedence; BOOTSTRAP_ADMIN_EMAIL is an alias.
#DX_AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# ── Dev convenience ──────────────────────────────────────────────────────────
# Skip the email-verification step (truthy: 1/true/yes). Dev only — never in prod.
#DX_AUTH_SKIP_EMAIL_VERIFICATION=

# ── OAuth: GitHub ────────────────────────────────────────────────────────────
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=
# Default: http://localhost:8080/auth/github/callback
#GITHUB_REDIRECT_URL=

# ── OAuth: Google (OIDC preset) ──────────────────────────────────────────────
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
# Default: http://localhost:8080/auth/google/callback
#GOOGLE_REDIRECT_URL=

# ── OAuth: Microsoft (OIDC preset) ───────────────────────────────────────────
#MICROSOFT_CLIENT_ID=
#MICROSOFT_CLIENT_SECRET=
# Azure AD tenant: a tenant id, or "common"/"organizations"/"consumers". Default: common
#MICROSOFT_TENANT=common
# Default: http://localhost:8080/auth/microsoft/callback
#MICROSOFT_REDIRECT_URL=

# ── OAuth: generic OIDC provider ─────────────────────────────────────────────
# For any standards-compliant OIDC issuer. CLIENT_ID, CLIENT_SECRET and
# ISSUER_URL are all required to enable it (issuer is used for discovery).
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_ISSUER_URL=https://issuer.example.com
# Default: http://localhost:8080/auth/oidc/callback
#OIDC_REDIRECT_URL=
# Space-separated scopes. Default: openid email profile
#OIDC_SCOPES=openid email profile
# Internal provider key (used in routes). Default: oidc
#OIDC_NAME=oidc
# Label shown on the login button. Default: SSO
#OIDC_DISPLAY_NAME=SSO

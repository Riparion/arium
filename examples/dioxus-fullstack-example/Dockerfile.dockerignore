# Build context is the workspace root (see docker-compose.yml `context: ../..`),
# so without this the multi-GB `target/` tree would stream into the build.
# Whitelist only the bundle the Dockerfile copies. Paths are relative to the
# context root. BuildKit prefers this `<Dockerfile>.dockerignore` over any
# context-root `.dockerignore`.
*
!target
target/*
!target/dx
target/dx/*
!target/dx/dioxus-fullstack-example
target/dx/dioxus-fullstack-example/*
!target/dx/dioxus-fullstack-example/release
target/dx/dioxus-fullstack-example/release/*
!target/dx/dioxus-fullstack-example/release/web
